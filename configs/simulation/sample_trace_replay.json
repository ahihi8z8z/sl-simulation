{
  "simulation": {
    "duration": 5.0,
    "seed": 42,
    "export_mode": 2
  },
  "services": [
    {
      "service_id": "svc-hello",
      "workload": {
        "generator": "trace",
        "trace_path": "configs/simulation/sample_trace.csv"
      },
      "min_instances": 1,
      "max_instances": 0,
      "lifecycle": {
        "cold_start_chain": [
          "null",
          "prewarm",
          "warm"
        ],
        "state_profile": "configs/simulation/sample_state_resources.csv",
        "states": [
          {
            "name": "null",
            "category": "stable"
          },
          {
            "name": "prewarm",
            "category": "stable"
          },
          {
            "name": "warm",
            "category": "stable",
            "service_bound": true,
            "reusable": true
          },
          {
            "name": "running",
            "category": "transient",
            "service_bound": true
          }
        ]
      },
      "service_time": {
        "mode": "fixed",
        "duration": 0.1
      }
    }
  ],
  "cluster": {
    "nodes": [
      {
        "node_id": "node-0",
        "cpu_capacity": 8.0,
        "memory_capacity": 8192
      }
    ]
  },
  "autoscaling": {
    "enabled": true,
    "reconcile_interval": 5.0
  },
  "monitoring": {
    "interval": 1.0,
    "max_history_length": 1000
  }
}
