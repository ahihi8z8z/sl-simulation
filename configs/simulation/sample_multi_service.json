{
  "simulation": {
    "duration": 30.0,
    "seed": 42,
    "export_mode": 1
  },
  "services": [
    {
      "service_id": "svc-api",
      "arrival_rate": 10.0,
      "job_size": 0.05,
      "max_concurrency": 8,
      "min_instances": 2,
      "max_instances": 0,
      "lifecycle": {
        "cold_start_chain": ["null", "prewarm", "warm"],
        "states": [
          {"name": "null", "category": "stable", "cpu": 0, "memory": 0},
          {"name": "prewarm", "category": "stable", "cpu": 0, "memory": 64},
          {"name": "warm", "category": "stable", "cpu": 0.1, "memory": 256, "service_bound": true, "reusable": true},
          {"name": "running", "category": "transient", "cpu": 0.5, "memory": 256, "service_bound": true, "reusable": false},
          {"name": "evicted", "category": "stable", "cpu": 0, "memory": 0, "reusable": false}
        ],
        "transitions": [
          {"from": "null", "to": "prewarm", "time": 0.3},
          {"from": "prewarm", "to": "warm", "time": 0.2},
          {"from": "warm", "to": "running", "time": 0.0},
          {"from": "running", "to": "warm", "time": 0.0},
          {"from": "warm", "to": "evicted", "time": 0.0},
          {"from": "prewarm", "to": "evicted", "time": 0.0}
        ]
      }
    },
    {
      "service_id": "svc-worker",
      "arrival_rate": 2.0,
      "job_size": 1.0,
      "max_concurrency": 2,
      "min_instances": 1,
      "max_instances": 0,
      "lifecycle": {
        "cold_start_chain": ["null", "prewarm", "code_loaded", "warm"],
        "states": [
          {"name": "null", "category": "stable", "cpu": 0, "memory": 0},
          {"name": "prewarm", "category": "stable", "cpu": 0.1, "memory": 256},
          {"name": "code_loaded", "category": "stable", "cpu": 0.3, "memory": 768, "service_bound": true},
          {"name": "warm", "category": "stable", "cpu": 0.5, "memory": 1024, "service_bound": true, "reusable": true},
          {"name": "running", "category": "transient", "cpu": 2.0, "memory": 1024, "service_bound": true, "reusable": false},
          {"name": "evicted", "category": "stable", "cpu": 0, "memory": 0, "reusable": false}
        ],
        "transitions": [
          {"from": "null", "to": "prewarm", "time": 0.5},
          {"from": "prewarm", "to": "code_loaded", "time": 0.8},
          {"from": "code_loaded", "to": "warm", "time": 0.3},
          {"from": "warm", "to": "running", "time": 0.0},
          {"from": "running", "to": "warm", "time": 0.0},
          {"from": "warm", "to": "evicted", "time": 0.0},
          {"from": "prewarm", "to": "evicted", "time": 0.0},
          {"from": "code_loaded", "to": "evicted", "time": 0.0}
        ]
      }
    },
    {
      "service_id": "svc-cron",
      "arrival_rate": 0.5,
      "job_size": 0.5,
      "max_concurrency": 1,
      "min_instances": 0,
      "max_instances": 0,
      "lifecycle": {
        "cold_start_chain": ["null", "prewarm", "warm"],
        "states": [
          {"name": "null", "category": "stable", "cpu": 0, "memory": 0},
          {"name": "prewarm", "category": "stable", "cpu": 0, "memory": 128},
          {"name": "warm", "category": "stable", "cpu": 0.2, "memory": 512, "service_bound": true, "reusable": true},
          {"name": "running", "category": "transient", "cpu": 1.0, "memory": 512, "service_bound": true, "reusable": false},
          {"name": "evicted", "category": "stable", "cpu": 0, "memory": 0, "reusable": false}
        ],
        "transitions": [
          {"from": "null", "to": "prewarm", "time": 0.4},
          {"from": "prewarm", "to": "warm", "time": 0.3},
          {"from": "warm", "to": "running", "time": 0.0},
          {"from": "running", "to": "warm", "time": 0.0},
          {"from": "warm", "to": "evicted", "time": 0.0},
          {"from": "prewarm", "to": "evicted", "time": 0.0}
        ]
      }
    }
  ],
  "cluster": {
    "nodes": [
      {
        "node_id": "node-0",
        "cpu_capacity": 16.0,
        "memory_capacity": 32768,
        "max_queue_depth": 200
      },
      {
        "node_id": "node-1",
        "cpu_capacity": 8.0,
        "memory_capacity": 16384,
        "max_queue_depth": 100
      }
    ]
  },
  "autoscaling": {
    "enabled": true,
    "reconcile_interval": 5.0
  },
  "controller": {
    "enabled": true,
    "interval": 5.0,
    "cpu_high": 0.7,
    "cpu_low": 0.2,
    "prewarm_max": 5
  },
  "monitoring": {
    "interval": 1.0,
    "max_history_length": 1000
  }
}
