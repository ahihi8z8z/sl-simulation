{
  "simulation": {
    "duration": 300.0,
    "seed": 42,
    "export_mode": 2,
    "drain_timeout": 30.0
  },
  "services": [
    {
      "service_id": "svc-hello",
      "workload": {
        "generator": "aggregate_trace",
        "trace_path": "configs/simulation/sample_aggregate_trace.csv",
        "scale": 2.0
      },
      "min_instances": 0,
      "max_instances": 0,
      "lifecycle": {
        "cold_start_chain": [
          "null",
          "prewarm",
          "warm"
        ],
        "states": [
          {
            "name": "null",
            "category": "stable",
            "cpu": 0,
            "memory": 0
          },
          {
            "name": "prewarm",
            "category": "stable",
            "cpu": 0,
            "memory": 128
          },
          {
            "name": "warm",
            "category": "stable",
            "cpu": 0.1,
            "memory": 256,
            "service_bound": true,
            "reusable": true
          },
          {
            "name": "running",
            "category": "transient",
            "cpu": 1.0,
            "memory": 256,
            "service_bound": true
          }
        ],
        "transitions": [
          {
            "from": "null",
            "to": "prewarm",
            "time": 0.5
          },
          {
            "from": "prewarm",
            "to": "warm",
            "time": 0.3
          }
        ]
      },
      "service_time": {
        "mode": "fixed",
        "duration": 0.1
      }
    }
  ],
  "cluster": {
    "nodes": [
      {
        "node_id": "node",
        "cpu_capacity": 8.0,
        "memory_capacity": 8192,
        "count": 2
      }
    ]
  },
  "autoscaling": {
    "enabled": true,
    "reconcile_interval": 1.0
  },
  "monitoring": {
    "interval": 1.0,
    "max_history_length": 1000
  }
}
