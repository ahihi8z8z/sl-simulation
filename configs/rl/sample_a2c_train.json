{
    "algorithm": "a2c",
    "env": "vahidinia",
    "n_envs": 4,
    "total_timesteps": 50000,
    "use_subproc": false,
    "device": "cpu",
    "learning_rate": 7e-4,
    "n_steps": 128,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "ent_coef": 0.01,
    "vf_coef": 0.5,
    "normalize_advantages": true,
    "log_interval": 1,
    "tensorboard_log": "./tensorboard/",
    "model_name": "a2c_vahidinia",
    "policy_kwargs": {
        "net_arch": {
            "pi": [32, 32, 32],
            "vf": [32, 16]
        }
    }
}
