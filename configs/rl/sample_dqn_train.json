{
    "algorithm": "dqn",
    "env": "discrete",
    "n_envs": 1,
    "total_timesteps": 50000,
    "device": "cpu",
    "learning_rate": 1e-4,
    "gamma": 0.99,
    "buffer_size": 100000,
    "batch_size": 32,
    "learning_starts": 1000,
    "train_freq": 4,
    "target_update_interval": 1000,
    "exploration_fraction": 0.1,
    "exploration_final_eps": 0.05,
    "log_interval": 1,
    "tensorboard_log": "./tensorboard/",
    "model_name": "dqn_serverless",
    "policy_kwargs": {
        "net_arch": [64, 64]
    }
}
